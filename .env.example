# Arcade API Key
# Get from: https://api.arcade.dev/dashboard/api-keys
ARCADE_API_KEY=arc_xxxxxxxxxxxxx

# Arcade Gateway Slug
# Create a gateway at: https://api.arcade.dev/dashboard/mcp-gateways
# Add Linear, GitHub, and Slack tools to your gateway
ARCADE_GATEWAY_SLUG=your-gateway-slug

# Arcade User ID (your email for user tracking)
ARCADE_USER_ID=you@example.com

# =============================================================================
# Project Output Configuration
# =============================================================================
# Base directory where generated projects are created.
# Each project gets its own subfolder with a separate git repo.
# Default: ./generations (relative to the repo)
#
# Example: Set to an absolute path outside the repo to avoid git conflicts
# GENERATIONS_BASE_PATH=/Users/yourname/projects/ai-generations

# =============================================================================
# GitHub Configuration (optional)
# =============================================================================
# If you want the agent to push code to GitHub, create the repo first and
# configure it here. The agent will commit and push to this repo.
# If not set, the agent will only use local git.
#
# Format: owner/repo (e.g., "myusername/my-project")
# GITHUB_REPO=owner/repo-name

# =============================================================================
# Agent Model Configuration (optional)
# =============================================================================
# Configure which model each agent uses. Options: haiku, sonnet, opus
# Sub-agents can also use "inherit" to use the orchestrator's model.
#
# Orchestrator - delegates to specialized agents (default: haiku)
# ORCHESTRATOR_MODEL=haiku
#
# Linear Agent - issue management (default: haiku)
# LINEAR_AGENT_MODEL=haiku
#
# Coding Agent - writes and tests code (default: sonnet)
# CODING_AGENT_MODEL=sonnet
#
# GitHub Agent - commits and PRs (default: haiku)
# GITHUB_AGENT_MODEL=haiku
#
# Slack Agent - notifications (default: haiku)
# SLACK_AGENT_MODEL=haiku

# =============================================================================
# Slack Configuration (optional)
# =============================================================================
# Note: Channel creation is not supported by Arcade's Slack integration.
# You must use a pre-existing channel.
#
# Default channel for notifications (channel name without #).
# The Slack sub-agent posts progress updates here.
SLACK_CHANNEL=new-channel

# =============================================================================
# Slack Trigger Configuration (slack_trigger.py)
# =============================================================================
# These variables are used by slack_trigger.py, the Socket Mode input layer
# that listens for Slack messages and triggers the autonomous agent harness.
# They are not needed if you only use autonomous_agent_demo.py (the CLI demo).

# Bot token for the Slack app.
# Found under "OAuth & Permissions" → "Bot User OAuth Token" in your app settings
# at api.slack.com/apps. Starts with xoxb-.
# Required bot token scopes: channels:history, channels:read, chat:write,
# groups:history, im:history, mpim:history (add more as needed for your workspace).
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token for Socket Mode.
# Found under "App Level Tokens" in your app settings. Must have the
# connections:write scope. Starts with xapp-.
# Socket Mode must also be enabled under "Socket Mode" in the app settings.
# SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Fallback project directory name used when a Slack message does not include
# a "project-name:" prefix. Equivalent to --project-dir in autonomous_agent_demo.py.
# Example: set to "my-app" and send "fix the login bug" to trigger the harness
# for the "my-app" project without typing a prefix every time.
# If not set, messages without a prefix will prompt the user to add one.
# DEFAULT_PROJECT=my-default-project
